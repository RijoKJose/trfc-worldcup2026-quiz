rules_version = '2';

service cloud.firestore {

match /databases/{database}/documents {

match /users/{userId} {
  allow read, write: if true;
}

    match /quizLeaderboards/{document=**} {
      allow read, write: if true;
    }

match /quizLeaderboards/{leaderboardId} {
  allow read, write: if true;
}

match /globalLeaderboards/{email} {
  allow read, write: if true;
}

match /quizzes/{quizId} {
  allow read, write: if true;
}

match /quizStatus/{statusId} {
  allow read, write: if true;
}

match /participants/{participantId} {
  allow read, write: if true;
}

}

}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users Collection
    match /users/{userId} {

      // Anyone can register and read users
      allow create: if true;
      allow read: if true;

      // Only authenticated admins can modify/delete users
      allow update, delete: if request.auth != null;
    }
match /settings/{document} {
allow read: if true; 
allow write: if request.auth != null; 
}
    // Quizzes Collection
    match /quizzes/{quizId} {

      // Everyone can view published quizzes
      allow read: if true;

      // Only authenticated admins can create/edit/delete quizzes
      allow create, update, delete: if request.auth != null;
    }

    // Participants Collection
match /participants/{participantId} {

    allow create: if true;

    allow read: if true;

    allow update: if true;

    allow delete: if request.auth != null;
}

    // Leaderboard Collection
    match /leaderboard/{entryId} {

      // Everyone can view leaderboard
      allow read: if true;

      // Only authenticated admins can modify leaderboard
      allow create, update, delete: if request.auth != null;
    }

    // Quiz Status Document
    match /quizStatus/{document} {

      // Everyone can check whether quiz is active
      allow read: if true;

      // Only authenticated admins can start/stop quizzes
      allow write: if request.auth != null;
    }

    // Settings Collection
    match /settings/{document} {

      // Everyone can read scoring settings
      allow read: if true;

      // Only authenticated admins can modify settings
      allow write: if request.auth != null;
    }
// Quiz-specific Leaderboard
match /quizLeaderboards/{entryId} {

    // Everyone can view leaderboard
    allow read: if true;

    // Everyone can create/update their score
    allow create, update: if true;

    // Only authenticated admins can delete entries
    allow delete: if request.auth != null;
}

// Global Leaderboard
match /globalLeaderboards/{entryId} {

    // Everyone can view global leaderboard
    allow read: if true;

    // Everyone can update their own cumulative score
    allow create, update: if true;

    // Only authenticated admins can delete entries
    allow delete: if request.auth != null;
}
  }
}
